# #!/bin/sh
# https://wiki.hypr.land/IPC/#events-list
# we can reimplement this without the additional layer, the link above is our main guide
reload_waybar_custom_windows() {
  # reload waybar custom/windows
  pkill -RTMIN+1 waybar
}

sleep_and_set_tiled() {
  sleep $1
  hyprctl dispatch settiled address:"0x$2"
}

sleep_and_pin() {
  previous_window=$(hyprctl -j clients | jq -r 'sort_by(.focusHistoryID) | .[1]')
  previous_pinned=$(echo "$previous_window" | jq -r '.pinned // false')
  
  sleep $1
  
  if [[ "$previous_pinned" == "true" ]]; then
    hyprctl dispatch pin address:"0x$2"
  fi
}

event_openwindow() {
    # WINDOWADDRESS WORKSPACENAME WINDOWCLASS WINDOWTITLE
    reload_waybar_custom_windows
    case "$WINDOWCLASS" in
        "discord")
            sleep_and_set_tiled 0.3 $WINDOWADDRESS
            ;;
        "com.freerdp.client.sdl3")
            sleep_and_set_tiled 3 $WINDOWADDRESS
            ;;
        "code")
            if [[ "$WINDOWTITLE" == "Visual Studio Code" ]]; then
              sleep_and_pin 0 $WINDOWADDRESS
            fi
            ;;
        "qutebrowser-twitch-chat")
            hyprctl dispatch layoutmsg mfact exact 0.85
            ;;
    esac
}

event_changefloatingmode() {
    # WINDOWADDRESS FLOATING
    wininfo=$(hyprctl -j clients | jq -r ".[] | select(.address==\"0x$WINDOWADDRESS\")")
    class=$(echo "$wininfo" | jq -r '.class')

    if [[ "$class" == "code" && "$FLOATING" == "1" ]]; then
        hyprctl dispatch resizewindowpixel exact 900 500,address:"0x$WINDOWADDRESS"
        hyprctl dispatch centerwindow address:"0x$WINDOWADDRESS"
    fi
}

event_activewindowv2() {
  # WINDOWADDRESS
  reload_waybar_custom_windows
  ~/.config/hypr/scripts/streamdeck/handler.sh & disown
}

event_workspacev2() {
  # WORKSPACEID WORKSPACENAME
  reload_waybar_custom_windows
}

event_focusedmon() {
  # MONNAME WORKSPACENAME
  reload_waybar_custom_windows
}

