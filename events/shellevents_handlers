event_screencastv2() {
  # STATE OWNER MONITOR

  TEMP_DIR="${XDG_RUNTIME_DIR:-/tmp}"
  SCREENCAST_FILE="$TEMP_DIR/screencast_status_$(id -u)"
  echo "$STATE" > "$SCREENCAST_FILE"
}

event_fullscreen() {
  # ENTER (0 if leaving fullscreen, 1 if entering)
  case $ENTER in
    0) ~/Projects/scripts/utils/swaync/ask-dnd.sh fullscreen-left & disown;;
    1) ~/Projects/scripts/utils/swaync/ask-dnd.sh fullscreen-entered & disown;;
  esac
}

