event_screencastv2() {
  # STATE OWNER MONITOR
  TEMP_DIR="${XDG_RUNTIME_DIR:-/tmp}"
  SCREENCAST_FILE="$TEMP_DIR/screencast_status_$(id -u)"
  echo "$STATE" > "$SCREENCAST_FILE"
  reload_waybar_screencast
}

event_fullscreen() {
  # ENTER (0 if leaving fullscreen, 1 if entering)
  reload_waybar
  case $ENTER in
    0) ~/.config/hypr/scripts/ask-dnd.sh fullscreen-left & disown;;
    1) ~/.config/hypr/scripts/ask-dnd.sh fullscreen-entered & disown;;
  esac
}

event_submap() {
  # SUBMAPNAME
  reload_waybar

  case $SUBMAPNAME in 
    "") kill_submap_yad;;
    *) ~/.config/hypr/scripts/submap/display.sh "$SUBMAPNAME"
  esac
}
